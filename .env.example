# ── REQUIRED ─────────────────────────────────────────────
# Groq API key — obtain from https://console.groq.com
# NEVER prefix with NEXT_PUBLIC_ (server-only secret)
GROQ_API_KEY=gsk_your_key_here

# ── RECOMMENDED ──────────────────────────────────────────
# Salt used to hash IP addresses for rate limiting.
# Generate with: openssl rand -hex 32
IP_HASH_SALT=change_this_to_random_string_in_production

# Public application URL (used for strict CORS in middleware)
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app

# NOTE:
# - Do not commit real secrets to version control.
# - Use .env.local for local development and ensure it is in .gitignore.
